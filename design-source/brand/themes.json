{
  "$comment": "Mythos Writer — Liquid Neon: the 10 built-in theme palettes. Six neon slots per theme (roles below). At runtime, border/glow/soft fills are derived from each slot at the current neon intensity (default 0.5). Users can also edit any slot with a full colour wheel, upload a custom wallpaper, or set \"No background\" for a transparent window.",
  "intensityDefault": 0.5,
  "derivation": {
    "border": "rgba(slot, 0.3 + 0.4*intensity)",
    "glow": "rgba(slot, 0.18 + 0.5*intensity)",
    "soft": "rgba(slot, 0.05 + 0.13*intensity)",
    "gradient": "linear-gradient(120deg, n1..n6)"
  },
  "slotRoles": [
    "Left panel · primary accent · Story Writer",
    "Center panel · wiki-links · Notes",
    "Right panel · AI agents",
    "Warm data · ideas & items",
    "Cool data · systems & lore",
    "Nav rail · timeline · window frame"
  ],
